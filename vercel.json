{
  "rewrites": [
    {
      "source": "/internal/econsec/sources.json",
      "destination": "/api/internal/econsec-sources"
    },
    {
      "source": "/internal/econsec/feeds.json",
      "destination": "/api/internal/econsec-feeds"
    },
    {
      "source": "/internal/econsec/alerts.json",
      "destination": "/api/internal/econsec-alerts"
    },
    {
      "source": "/internal/econsec/feed-history.json",
      "destination": "/api/internal/econsec-feed-history"
    }
  ],
  "headers": [
    {
      "source": "/internal/(.*)",
      "headers": [
        { "key": "X-Robots-Tag", "value": "noindex, nofollow" },
        { "key": "Cache-Control", "value": "private, no-store" }
      ]
    },
    {
      "source": "/api/internal/(.*)",
      "headers": [
        { "key": "X-Robots-Tag", "value": "noindex, nofollow" },
        { "key": "Cache-Control", "value": "private, no-store" }
      ]
    },
    {
      "source": "/(internal/econsec/feeds.json|api/internal/econsec-feeds)",
      "headers": [
        { "key": "Cache-Control", "value": "private, s-maxage=900, stale-while-revalidate=1800" }
      ]
    }
  ]
}
